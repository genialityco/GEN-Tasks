# ==========================================================================
# GEN-Task Backend (NestJS) - variables de entorno
# Copia este archivo a .env y completa los valores. NUNCA subas .env al repo.
# ==========================================================================

# Puerto del servidor
PORT=4000

# Origen permitido para CORS (frontend Next.js)
FRONTEND_ORIGIN=http://localhost:3000

# --------------------------------------------------------------------------
# Firebase Admin SDK
# Opcion A (recomendada en local): ruta al archivo de service account JSON.
# --------------------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# --------------------------------------------------------------------------
# Opcion B (recomendada en produccion / CI): credenciales por variables.
# Si se define FIREBASE_PROJECT_ID, estas tienen prioridad sobre la ruta.
# La clave privada debe ir entre comillas y con los \n escapados.
# --------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Bucket de Firebase Storage (ej: my-project.appspot.com)
FIREBASE_STORAGE_BUCKET=

# --------------------------------------------------------------------------
# WhatsApp Cloud API
# --------------------------------------------------------------------------
WHATSAPP_VERIFY_TOKEN=cambia-este-token-de-verificacion
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
